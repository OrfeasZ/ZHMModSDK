--- a/portfile.cmake
+++ b/portfile.cmake
@@ -14,6 +14,15 @@
 )
 file(REMOVE_RECURSE "${SOURCE_PATH}/external/crashpad/third_party/zlib/zlib")
 
+# sentry-native hardcodes `-Werror -Wall` for the clang-cl build with a fixed
+# suppression list that predates clang 21's stricter warnings
+# (-Wimplicit-void-ptr-cast, -Wnrvo, -Wc++-keyword, -Wpadded, ...). Those fire
+# on its own C sources and abort the cross build. Drop -Werror so the new
+# warnings stay non-fatal (we still keep -Wall).
+vcpkg_replace_string("${SOURCE_PATH}/CMakeLists.txt"
+    "$<BUILD_INTERFACE:-Werror -Wall>"
+    "$<BUILD_INTERFACE:-Wall>")
+
 vcpkg_list(SET options)
 
 if(NOT "backend" IN_LIST FEATURES)
